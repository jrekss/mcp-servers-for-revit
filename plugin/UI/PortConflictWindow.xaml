<Window x:Class="revit_mcp_plugin.UI.PortConflictWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Port Conflict Detected" Height="220" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Border CornerRadius="8" Background="#FFFFFF" BorderBrush="#E5E5EA" BorderThickness="1" Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="2" Opacity="0.15"/>
        </Border.Effect>
        
        <Grid MouseLeftButtonDown="Grid_MouseLeftButtonDown">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header / Title -->
            <StackPanel Grid.Row="0" Margin="20,16,20,8" Orientation="Horizontal">
                <Path Data="M12,2L1,21H23L12,2M12,6L19.53,19H4.47L12,6M11,10V14H13V10H11M11,16V18H13V16H11Z" 
                      Fill="#FF9500" Width="20" Height="20" Stretch="Uniform" Margin="0,0,10,0"/>
                <TextBlock Text="Port Conflict Detected" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#1C1C1E"/>
            </StackPanel>

            <!-- Content Area -->
            <TextBlock Grid.Row="1" Margin="20,8,20,12" 
                       Text="Port 8080 is currently occupied by another Revit session. Would you like to force switch the MCP Server to this window?" 
                       FontSize="13" Foreground="#3A3A3C" TextWrapping="Wrap" LineHeight="18"/>

            <!-- Buttons -->
            <Border Grid.Row="2" Background="#F2F2F7" CornerRadius="0,0,7,7" BorderBrush="#E5E5EA" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="15,12">
                    <!-- Cancel Button -->
                    <Button x:Name="CancelButton" Content="Cancel" Click="CancelButton_Click" Width="85" Height="30" Margin="0,0,10,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#E5E5EA"/>
                                <Setter Property="Foreground" Value="#1C1C1E"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D1D1D6"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Force Switch Button -->
                    <Button x:Name="ForceSwitchButton" Content="Force Switch" Click="ForceSwitchButton_Click" Width="105" Height="30">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#007AFF"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#0062CC"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
